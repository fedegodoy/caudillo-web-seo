---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const PHONE_RAW = '5491136651186';
const WHATSAPP_LINK = `https://wa.me/${PHONE_RAW}?text=Hola!%20Quiero%20reservar%20una%20mesa%20en%20Caudillo%20Bar`;

// Iconos: por ahora SVG inline limpios. Cuando Fede pase los íconos personalizados, se reemplazan acá.
const tabs = [
  { href: '/',         label: 'Inicio',   iconKey: 'home' },
  { href: '/menu',     label: 'Carta',    iconKey: 'menu' },
  { href: WHATSAPP_LINK, label: 'Reservar', iconKey: 'reserve', external: true, primary: true },
  { href: '/eventos',  label: 'Eventos',  iconKey: 'events' },
  { href: '/delivery', label: 'Delivery', iconKey: 'delivery' },
];
---

<nav class="bottom-tab-bar" aria-label="Navegación rápida">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class:list={[
        'bottom-tab-bar__item',
        { 'bottom-tab-bar__item--active': currentPath === tab.href },
        { 'bottom-tab-bar__item--primary': tab.primary },
      ]}
      target={tab.external ? '_blank' : undefined}
      rel={tab.external ? 'noopener' : undefined}
      aria-label={tab.label}
    >
      <span class="bottom-tab-bar__icon" aria-hidden="true">
        {tab.iconKey === 'home' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        )}
        {tab.iconKey === 'menu' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="8" y1="13" x2="16" y2="13" />
            <line x1="8" y1="17" x2="16" y2="17" />
            <line x1="8" y1="9" x2="10" y2="9" />
          </svg>
        )}
        {tab.iconKey === 'reserve' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
        )}
        {tab.iconKey === 'events' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5.8 11.3 2 22l10.7-3.79" />
            <path d="M4 3h.01" />
            <path d="M22 8h.01" />
            <path d="M15 2h.01" />
            <path d="M22 20h.01" />
            <path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10" />
            <path d="m22 13-1.4.7c-.84.42-1.84.06-2.26-.78a1.7 1.7 0 0 0-2.18-.88L13 13.4" />
            <path d="m11 2 .33.97c.4 1.18 1.65 1.85 2.86 1.55l.31-.08" />
            <path d="m8 14-3 3" />
            <path d="m13 5-1 1" />
          </svg>
        )}
        {tab.iconKey === 'delivery' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="5.5" cy="17.5" r="2.5" />
            <circle cx="18.5" cy="17.5" r="2.5" />
            <path d="M15 6h4l2 5" />
            <path d="M3 6h6l3 6" />
            <path d="M3 17.5h2" />
            <path d="M14 17.5h2" />
            <path d="M21 11v6.5" />
            <path d="M9 12v5.5" />
          </svg>
        )}
      </span>
      <span class="bottom-tab-bar__label">{tab.label}</span>
    </a>
  ))}
</nav>

<style>
  .bottom-tab-bar {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-top: var(--glass-border);
    padding-bottom: env(safe-area-inset-bottom);
    height: calc(60px + env(safe-area-inset-bottom));
  }

  @media (min-width: 768px) {
    .bottom-tab-bar {
      display: none;
    }
  }

  .bottom-tab-bar__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    min-height: 48px;
    min-width: 48px;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .bottom-tab-bar__item--active {
    color: var(--color-accent);
  }

  .bottom-tab-bar__item--primary {
    color: var(--color-accent);
  }

  .bottom-tab-bar__item--primary .bottom-tab-bar__icon {
    background: var(--color-accent);
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -8px;
    box-shadow: 0 4px 12px rgba(200, 53, 42, 0.4);
  }

  .bottom-tab-bar__item--primary .bottom-tab-bar__icon svg {
    width: 20px;
    height: 20px;
  }

  .bottom-tab-bar__icon {
    width: 22px;
    height: 22px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .bottom-tab-bar__icon svg {
    width: 100%;
    height: 100%;
  }

  .bottom-tab-bar__label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
  }
</style>
