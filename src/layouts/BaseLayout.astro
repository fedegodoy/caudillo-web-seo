---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomTabBar from '../components/BottomTabBar.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

import '../styles/global.css';
import '../styles/components.css';
import '../styles/comic.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
  floatingCTAText?: string;
  floatingCTAHref?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  schema,
  floatingCTAText = 'Ver la Carta',
  floatingCTAHref = '/menu',
} = Astro.props;

const currentPath = new URL(Astro.request.url).pathname;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      schema={schema}
    />
    <script type="speculationrules">
      {
        "prerender": [
          {
            "source": "list",
            "urls": ["/menu", "/restaurante", "/eventos", "/contacto"]
          }
        ]
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">
      Saltar al contenido principal
    </a>

    <Header currentPath={currentPath} />
    <div class="header-spacer"></div>

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    <BottomTabBar currentPath={currentPath} />
    <FloatingCTA text={floatingCTAText} href={floatingCTAHref} />

    <!-- GSAP + ScrollTrigger + SplitText (Club GreenSock free tier via CDN) -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/ScrollTrigger.min.js"></script>

    <script>
      function initGSAP() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
          setTimeout(initGSAP, 50);
          return;
        }

        gsap.registerPlugin(ScrollTrigger);

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) return;

        // ── Ocultar elementos ANTES de animarlos (GSAP hace el set, no CSS) ──
        gsap.set('.reveal-comic', { opacity: 0, y: 40, rotation: -0.8 });
        gsap.set('.reveal-slide-left', { opacity: 0, x: -50 });
        gsap.set('.reveal-slide-right', { opacity: 0, x: 50 });
        gsap.set('.reveal', { opacity: 0, y: 20 });

        // ── HERO: secuencia de entrada ──
        const heroKicker  = document.querySelector('.hero__kicker');
        const heroTitle   = document.querySelector('.hero__title');
        const heroSub     = document.querySelector('.hero__subtitle');
        const heroActions = document.querySelector('.hero__actions');

        if (heroTitle) {
          const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
          heroTl
            .from(heroKicker,  { y: 20, opacity: 0, duration: 0.5 })
            .from(heroTitle,   { y: 60, opacity: 0, duration: 0.8, skewY: 2 }, '-=0.2')
            .from(heroSub,     { y: 20, opacity: 0, duration: 0.5 }, '-=0.4')
            .from(heroActions?.children ? Array.from(heroActions.children) : [],
                  { y: 16, opacity: 0, duration: 0.4, stagger: 0.12 }, '-=0.3');
        }

        // ── SCROLL REVEAL: .reveal-comic ──
        document.querySelectorAll('.reveal-comic').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).style.transitionDelay || '0') / 1000;
          gsap.to(el, {
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
            opacity: 1,
            y: 0,
            rotation: 0,
            duration: 0.7,
            delay,
            ease: 'back.out(1.4)',
          });
        });

        // ── SCROLL REVEAL: .reveal-slide-left ──
        document.querySelectorAll('.reveal-slide-left').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).style.transitionDelay || '0') / 1000;
          gsap.to(el, {
            scrollTrigger: { trigger: el, start: 'top 90%', once: true },
            opacity: 1,
            x: 0,
            duration: 0.6,
            delay,
            ease: 'power2.out',
          });
        });

        // ── SCROLL REVEAL: .reveal y .reveal-slide-right ──
        document.querySelectorAll('.reveal, .reveal-slide-right').forEach((el) => {
          const isRight = el.classList.contains('reveal-slide-right');
          gsap.to(el, {
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
            opacity: 1,
            x: 0,
            y: 0,
            duration: 0.6,
            ease: 'power2.out',
          });
        });

        // ── SPRING HOVER en cards ──
        document.querySelectorAll('.card-comic').forEach((card) => {
          const el = card as HTMLElement;
          el.addEventListener('mouseenter', () => {
            gsap.to(el, {
              y: -6, rotation: -0.4,
              boxShadow: '8px 8px 0 rgba(200, 53, 42, 0.35)',
              duration: 0.35, ease: 'back.out(2)', overwrite: 'auto',
            });
          });
          el.addEventListener('mouseleave', () => {
            gsap.to(el, {
              y: 0, rotation: 0,
              boxShadow: '0px 0px 0 rgba(200, 53, 42, 0)',
              duration: 0.4, ease: 'elastic.out(1, 0.6)', overwrite: 'auto',
            });
          });
        });
      }

      document.addEventListener('DOMContentLoaded', initGSAP);
    </script>
  </body>
</html>
