---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Novedades de Caudillo | Blog"
  description="Novedades, recetas, eventos y todo lo que pasa en Caudillo Bar, Saavedra. El blog del bodegón de CABA Norte."
>
  <section class="section" style="padding-top: var(--space-20);">
    <div class="container">
      <h1>Novedades de Caudillo.</h1>
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div style="display: flex; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-8);">
        <button class="tab tab--active" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Todos</button>
        <button class="tab" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Bar</button>
        <button class="tab" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Restaurante</button>
        <button class="tab" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Eventos</button>
        <button class="tab" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Música</button>
        <button class="tab" style="flex: none; padding: var(--space-2) var(--space-4); border-radius: var(--radius-pill);">Delivery</button>
      </div>

      <!-- Placeholder — posts se agregan en Fase 7 -->
      <div class="grid-highlights">
        <div class="card" style="text-align: center; padding: var(--space-12);">
          <p style="font-size: 2rem;">📝</p>
          <h3 class="card__title" style="margin-top: var(--space-4);">Próximamente</h3>
          <p class="card__text" style="margin-top: var(--space-2);">
            El blog de Caudillo arranca con la web. Recetas, novedades del barrio y lo que pasa en la terraza.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
