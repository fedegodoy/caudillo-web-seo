---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  { q: "¿Tienen terraza al aire libre?", a: "Sí, tenemos la mejor terraza de Saavedra, abierta todo el año y techada ante lluvia." },
  { q: "¿Se puede reservar para festejos?", a: "Claro. Reservamos mesas para grupos o la terraza entera para eventos privados." },
  { q: "¿Son pet-friendly?", a: "Totalmente. Tu perro es bienvenido, especialmente en la terraza y vereda." },
  { q: "¿Tienen opciones vegetarianas?", a: "Sí, el sándwich Artigas y varios platos de nuestra cocina son aptos para vegetarianos." },
  { q: "¿Hacen envíos a domicilio?", a: "Sí, operamos en Saavedra, Núñez y Coghlan a través de apps y pedidos directos." },
  { q: "¿Tienen menú ejecutivo?", a: "De lunes a viernes al mediodía tenemos las mejores opciones de cocina criolla para el almuerzo." },
  { q: "¿Hay estacionamiento cerca?", a: "Al ser zona residencial de Saavedra, suele haber lugar en las calles aledañas a Crámer." },
  { q: "¿Qué tragos recomiendan?", a: "El Ferroviario y el Pico y Pala son nuestros clásicos insignia. No fallan." },
  { q: "¿Aceptan grupos grandes para cenar?", a: "Sí, recomendamos reservar con 48hs de anticipación para mesas de más de 8 personas." },
  { q: "¿Tienen Wi-Fi para trabajar?", a: "Tenemos Wi-Fi de alta velocidad, ideal para un café rápido o un almuerzo de trabajo." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    }
  }))
};
---

<BaseLayout
  title="Contacto y Reservas | Caudillo Bar Saavedra"
  description="Crámer 3198, Saavedra. Reservas por WhatsApp. Horarios de mediodía y noche."
  schema={faqSchema}
  floatingCTAText="Reservar Mesa"
  floatingCTAHref="https://wa.me/"
>
  <section class="section" style="padding-top: var(--space-20);">
    <div class="container">
      <h1>Vení a Caudillo.</h1>
      <h2 style="margin-top: var(--space-4);">Estamos en Crámer 3198.</h2>
      <p style="margin-top: var(--space-4); max-width: 700px;">
        A pasos de la estación y rodeado de verde. Venite cuando quieras, pero si son muchos, avisá por WhatsApp y te armamos bien la mesa.
      </p>
    </div>
  </section>

  <!-- MAPA -->
  <section class="section reveal">
    <div class="container">
      <div style="border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16/9; background: var(--color-bg-card);">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3287.2!2d-58.472322!3d-34.5552855!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb70064a4b019%3A0x4258d795fdd55b8c!2sCaudillo%20Bar!5e0!3m2!1ses!2sar!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Caudillo Bar en Google Maps"
        ></iframe>
      </div>
      <a href="https://www.google.com/maps/place/Caudillo+Bar/@-34.5552855,-58.472322,17z/data=!3m1!4b1!4m6!3m5!1s0x95bcb70064a4b019:0x4258d795fdd55b8c" class="btn btn-secondary" style="margin-top: var(--space-4);" target="_blank" rel="noopener">
        Cómo llegar
      </a>
    </div>
  </section>

  <!-- HORARIOS -->
  <section class="section reveal">
    <div class="container">
      <div class="grid-services" style="max-width: 500px;">
        <div class="card">
          <h3 class="card__title">Mediodía</h3>
          <p class="card__text">Lunes a Viernes 12:00-15:30</p>
        </div>
        <div class="card">
          <h3 class="card__title">Noche</h3>
          <p class="card__text">Martes a Domingo 19:00-23:30</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO DIRECTO -->
  <section class="section reveal">
    <div class="container">
      <div class="grid-services" style="max-width: 500px;">
        <a href="https://wa.me/" class="card" target="_blank" rel="noopener">
          <h3 class="card__title">💬 WhatsApp</h3>
          <p class="card__text">Reservas y consultas</p>
        </a>
        <a href="https://instagram.com/caudillobar" class="card" target="_blank" rel="noopener">
          <h3 class="card__title">📸 Instagram</h3>
          <p class="card__text">@caudillobar</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section reveal" id="faq">
    <div class="container" style="max-width: 700px;">
      <h2>Preguntas Frecuentes</h2>
      <div style="margin-top: var(--space-6);">
        {faqs.map((faq, i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-item__question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              <span>{faq.q}</span>
              <span class="faq-item__icon">+</span>
            </button>
            <div class="faq-item__answer" id={`faq-answer-${i}`} role="region">
              <p>{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // FAQ Accordion logic — solo una abierta a la vez
  document.querySelectorAll('.faq-item__question').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.closest('.faq-item');
      const isOpen = item?.classList.contains('faq-item--open');

      // Close all
      document.querySelectorAll('.faq-item').forEach(el => {
        el.classList.remove('faq-item--open');
        el.querySelector('.faq-item__question')?.setAttribute('aria-expanded', 'false');
      });

      // Toggle clicked
      if (!isOpen && item) {
        item.classList.add('faq-item--open');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
