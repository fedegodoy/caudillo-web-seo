---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["Bar", "Restaurant"],
  "@id": "https://caudillobar.com.ar/#organization",
  "name": "Caudillo Bar",
  "alternateName": "El Bodegón de Saavedra",
  "url": "https://caudillobar.com.ar",
  "telephone": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Crámer 3180",
    "addressLocality": "Saavedra",
    "addressRegion": "CABA",
    "postalCode": "C1429",
    "addressCountry": "AR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.55390,
    "longitude": -58.48750
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "12:00",
      "closes": "15:30",
      "description": "Mediodía"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "19:00",
      "closes": "23:30",
      "description": "Noche"
    }
  ],
  "servesCuisine": ["Cocina criolla", "Cocina argentina", "Bar"],
  "priceRange": "$$",
  "image": "https://caudillobar.com.ar/images/og-caudillo-bar.jpg",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Terraza al aire libre", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Pet-friendly", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Música en vivo", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Salón para eventos", "value": true }
  ],
  "potentialAction": [
    {
      "@type": "ReserveAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://wa.me/",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "result": { "@type": "Reservation", "name": "Reserva de mesa" }
    },
    {
      "@type": "OrderAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.rappi.com.ar/",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "deliveryMethod": "http://purl.org/goodrelations/v1#DeliveryModeOwnFleet"
    }
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": "https://caudillobar.com.ar/menu"
  }
};
---

<BaseLayout
  title="Caudillo | El Bodegón Moderno de Saavedra (CABA Norte)"
  description="Comida criolla de la casa, terraza real y vermut en Crámer 3180. Entre Saavedra, Núñez y Coghlan. Sin vueltas, como se come en el barrio."
  schema={schema}
>
  <!-- HERO SECTION -->
  <section class="hero" id="hero">
    <div class="hero__bg" style="background-color: var(--color-bg);"></div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1>El Bodegón<br />de Saavedra.</h1>
      <p class="hero__subtitle">
        Cocina criolla de barrio. Bar en la terraza.<br />Un espacio argentino.
      </p>
      <div class="hero__meta">
        <span>📍 Crámer 3180, Saavedra</span>
        <span>🕐 Mar-Dom 19:00-23:30</span>
      </div>
      <div class="hero__actions">
        <a href="/menu" class="btn btn-primary">Ver la Carta</a>
        <a href="/eventos" class="btn btn-secondary">Reservar Terraza</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section reveal" id="intro">
    <div class="container">
      <h2>Comida honesta para el que labura y el que disfruta.</h2>
      <p style="margin-top: var(--space-4); max-width: 700px;">
        En Caudillo no inventamos la pólvora, cuidamos el fuego. Somos el secreto a voces de Saavedra, a cinco minutos de Núñez y Coghlan. Acá venís a hidratarte con un buen vino y a comer platos que tienen algo que decir. Sin apuro, sin pretensiones. Como en casa de alguien que cocina bien.
      </p>
    </div>
  </section>

  <!-- DESTACADOS -->
  <section class="section reveal" id="destacados">
    <div class="container">
      <div class="grid-highlights">
        <div class="card reveal reveal-stagger">
          <h3 class="card__title">🏠 Nuestra Terraza</h3>
          <p class="card__text">El mejor spot al aire libre del barrio. Pet-friendly y abierta para juntar a la banda.</p>
        </div>
        <div class="card reveal reveal-stagger">
          <h3 class="card__title">🥩 Los Caudillos</h3>
          <p class="card__text">Sándwiches con bife de chorizo, bondiola desmechada y milanesa real. El tipo de comida que no te deja con hambre.</p>
        </div>
        <div class="card reveal reveal-stagger">
          <h3 class="card__title">🍷 Cultura del Vermut</h3>
          <p class="card__text">Ferroviario, Pico y Pala y los clásicos de siempre. Buena compañía incluida.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RESEÑAS GOOGLE -->
  <section class="section reveal" id="resenas">
    <div class="container reviews">
      <div class="reviews__stars">★★★★★</div>
      <div class="reviews__rating">4.8 / 5</div>
      <p class="reviews__count">Basado en reseñas de Google</p>
      <div class="reviews__grid">
        <div class="review-card">
          <p class="review-card__text">"Increíble lugar, la bondiola es de otro planeta y la terraza una joya del barrio."</p>
          <p class="review-card__author">— Juan P.</p>
          <p class="review-card__stars">★★★★★</p>
        </div>
        <div class="review-card">
          <p class="review-card__text">"El mejor vermut de la zona. Ambiente relajado y comida honesta. Vuelvo siempre."</p>
          <p class="review-card__author">— María G.</p>
          <p class="review-card__stars">★★★★★</p>
        </div>
        <div class="review-card">
          <p class="review-card__text">"El patio es genial, vinimos con el perro y nos trataron bárbaro. Sándwiches enormes."</p>
          <p class="review-card__author">— Carlos R.</p>
          <p class="review-card__stars">★★★★★</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTAs SERVICIOS -->
  <section class="section reveal" id="servicios">
    <div class="container">
      <div class="grid-services">
        <a href="/eventos" class="card">
          <h3 class="card__title">🎉 Eventos</h3>
          <p class="card__text">Tu fiesta en la terraza de Saavedra.</p>
        </a>
        <a href="/delivery" class="card">
          <h3 class="card__title">🛵 Delivery</h3>
          <p class="card__text">Pedí por Rappi y te llega en minutos.</p>
        </a>
        <a href="/el-bar" class="card">
          <h3 class="card__title">🎵 Música en vivo</h3>
          <p class="card__text">Indie, rock y buena onda. Los fines de semana.</p>
        </a>
        <a href="/el-bar" class="card">
          <h3 class="card__title">🍺 El Bar</h3>
          <p class="card__text">Nuestra historia y por qué estamos en Saavedra.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- MAPA + CONTACTO -->
  <section class="section reveal" id="ubicacion">
    <div class="container" style="text-align: center;">
      <h2>📍 Crámer 3180, Saavedra</h2>
      <div style="margin-top: var(--space-6); border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16/9; background: var(--color-bg-card);">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3286.123456!2d-58.4875!3d-34.5539!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sCr%C3%A1mer+3180!5e0!3m2!1ses!2sar!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Caudillo Bar en Google Maps"
        ></iframe>
      </div>
      <div style="margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="https://maps.google.com/?q=Cramer+3180+Saavedra+Buenos+Aires" class="btn btn-secondary" target="_blank" rel="noopener">
          Cómo llegar
        </a>
        <a href="https://wa.me/" class="btn btn-primary" target="_blank" rel="noopener">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
