---
import BaseLayout from '../layouts/BaseLayout.astro';
import Marquee from '../components/Marquee.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": ["Bar", "Restaurant"],
  "@id": "https://caudillobar.com.ar/#organization",
  "name": "Caudillo Bar",
  "alternateName": "El Bodegón de Saavedra",
  "url": "https://caudillobar.com.ar",
  "telephone": "",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Crámer 3198",
    "addressLocality": "Saavedra",
    "addressRegion": "CABA",
    "postalCode": "C1429",
    "addressCountry": "AR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.55390,
    "longitude": -58.48750
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "12:00",
      "closes": "15:30",
      "description": "Mediodía"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "19:00",
      "closes": "23:30",
      "description": "Noche"
    }
  ],
  "servesCuisine": ["Cocina criolla", "Cocina argentina", "Bar"],
  "priceRange": "$$",
  "image": "https://caudillobar.com.ar/images/og-caudillo-bar.jpg",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Terraza al aire libre", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Pet-friendly", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Música en vivo", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Salón para eventos", "value": true }
  ],
  "potentialAction": [
    {
      "@type": "ReserveAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://wa.me/",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "result": { "@type": "Reservation", "name": "Reserva de mesa" }
    },
    {
      "@type": "OrderAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.rappi.com.ar/restaurantes/259123-caudillo-bar",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "deliveryMethod": "http://purl.org/goodrelations/v1#DeliveryModeOwnFleet"
    }
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": "https://caudillobar.com.ar/menu"
  }
};

const marqueeItems = [
  'Vermut de la casa',
  'Bondiola desmechada',
  'Terraza pet-friendly',
  'Vinos boutique',
  'Música en vivo',
  'Pastel de papas',
  'Ferroviario',
  'Pico y Pala',
  'Negroni',
  'Bife de chorizo',
  'Saavedra, CABA',
];
---

<BaseLayout
  title="Caudillo | El Bodegón Moderno de Saavedra (CABA Norte)"
  description="Comida criolla de la casa, terraza real y vermut en Crámer 3198. Entre Saavedra, Núñez y Coghlan. Sin vueltas, como se come en el barrio."
  schema={schema}
>
  <!-- ============================================
       HERO SECTION
       ============================================ -->
  <section class="hero halftone" id="hero">
    <div class="hero__bg" style="background-color: var(--color-bg);">
      <!-- ASSET BOX: Hero principal -->
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__kicker text-stencil text-stencil--red">Crámer 3198 — Saavedra</p>
      <h1 class="hero__title">El Bodegón<br />de Saavedra.</h1>
      <p class="hero__subtitle">
        Cocina criolla de barrio. Bar en la terraza.<br />Un espacio argentino.
      </p>
      <div class="hero__actions">
        <a href="/menu" class="btn btn-primary ink-hover">Ver la Carta</a>
        <a href="/eventos" class="btn btn-secondary">Reservar Terraza</a>
      </div>
    </div>
    <!-- Asset placeholder for hero illustration -->
    <div class="hero__asset-note">
      <div class="asset-placeholder" style="position: absolute; bottom: 20px; right: 20px; width: 280px; min-height: 120px; opacity: 0.7;">
        <span class="asset-placeholder__label">Hero BG</span>
        <span class="asset-placeholder__specs">2560x1440px &middot; 16:9<br/>Ilustracion: El Caudillo en la puerta del bar (esquina en picado, como afiche 3) o video loop de vinetas animadas</span>
        <span class="asset-placeholder__type">ilustracion / video</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE TICKER #1
       ============================================ -->
  <Marquee items={marqueeItems} />

  <!-- ============================================
       INTRO — Comic Panel
       ============================================ -->
  <section class="section comic-panel reveal-comic" id="intro">
    <div class="container intro-layout">
      <div class="intro-layout__text">
        <h2 class="text-stencil text-stencil--large">Comida<br/>honesta.</h2>
        <p style="margin-top: var(--space-4); max-width: 600px;">
          En Caudillo no inventamos la polvora, cuidamos el fuego. Somos el secreto a voces de Saavedra, a cinco minutos de Nunez y Coghlan. Aca venis a hidratarte con un buen vino y a comer platos que tienen algo que decir. Sin apuro, sin pretensiones. Como en casa de alguien que cocina bien.
        </p>
      </div>
      <div class="intro-layout__asset">
        <div class="asset-placeholder" style="aspect-ratio: 3/4; width: 100%;">
          <span class="asset-placeholder__label">El Caudillo</span>
          <span class="asset-placeholder__specs">800x1067px &middot; 3:4<br/>Ilustracion: El Caudillo de frente, sosteniendo un vaso de vino, mirada al espectador. Estilo afiche 1 (plano medio)</span>
          <span class="asset-placeholder__type">ilustracion</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       DESTACADOS — 3 cards estilo vineta
       ============================================ -->
  <section class="section" id="destacados">
    <div class="container">
      <div class="grid-highlights">
        <!-- Card 1: Terraza -->
        <div class="card-comic reveal-comic" style="transition-delay: 0ms;">
          <div class="card-comic__image-slot asset-placeholder" style="aspect-ratio: 4/3;">
            <span class="asset-placeholder__label">Terraza</span>
            <span class="asset-placeholder__specs">800x600 &middot; 4:3<br/>Ilustracion: La terraza del bar con gente, plantas, el perro. Vista desde arriba tipo afiche 3. BYN + manteles rojos</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Nuestra Terraza</h3>
            <p class="card-comic__text">El mejor spot al aire libre del barrio. Pet-friendly y abierta para juntar a la banda.</p>
          </div>
        </div>

        <!-- Card 2: Los Caudillos -->
        <div class="card-comic reveal-comic" style="transition-delay: 100ms;">
          <div class="card-comic__image-slot asset-placeholder" style="aspect-ratio: 4/3;">
            <span class="asset-placeholder__label">Los Caudillos</span>
            <span class="asset-placeholder__specs">800x600 &middot; 4:3<br/>Ilustracion: Plato con sandwich desde arriba, estilo food comic. Entintado pesado, vapor saliendo. BYN</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Los Caudillos</h3>
            <p class="card-comic__text">Sandwiches con bife de chorizo, bondiola desmechada y milanesa real. El tipo de comida que no te deja con hambre.</p>
          </div>
        </div>

        <!-- Card 3: Vermut -->
        <div class="card-comic reveal-comic" style="transition-delay: 200ms;">
          <div class="card-comic__image-slot asset-placeholder" style="aspect-ratio: 4/3;">
            <span class="asset-placeholder__label">Vermut</span>
            <span class="asset-placeholder__specs">800x600 &middot; 4:3<br/>Ilustracion: Barra con botellas, mano sirviendo un Negroni. Cross-hatching en las sombras. Liquido rojo selectivo</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Cultura del Vermut</h3>
            <p class="card-comic__text">Ferroviario, Pico y Pala y los clasicos de siempre. Buena compania incluida.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       INK DIVIDER
       ============================================ -->
  <div class="ink-divider"></div>

  <!-- ============================================
       VINETA NARRATIVA — La historia en 3 frames
       ============================================ -->
  <section class="section" id="historia-visual">
    <div class="container">
      <h2 class="text-stencil" style="text-align: center; margin-bottom: var(--space-8);">Una noche en Caudillo</h2>
      <div class="vineta-strip">
        <div class="vineta-strip__frame reveal-slide-left" style="transition-delay: 0ms;">
          <div class="asset-placeholder" style="aspect-ratio: 3/4;">
            <span class="asset-placeholder__label">Vineta 1</span>
            <span class="asset-placeholder__specs">600x800 &middot; 3:4<br/>Ilustracion: El Caudillo caminando por la vereda de Saavedra, noche, faroles. BYN + vincha roja. Angulo contrapicado</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <p class="vineta-strip__caption">Llega al barrio.</p>
        </div>
        <div class="vineta-strip__frame reveal-slide-left" style="transition-delay: 150ms;">
          <div class="asset-placeholder" style="aspect-ratio: 3/4;">
            <span class="asset-placeholder__label">Vineta 2</span>
            <span class="asset-placeholder__specs">600x800 &middot; 3:4<br/>Ilustracion: Interior del bar, el Caudillo en la barra pidiendo. Piso damero, botellas atras. Chiaroscuro fuerte</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <p class="vineta-strip__caption">Se sienta en la barra.</p>
        </div>
        <div class="vineta-strip__frame reveal-slide-left" style="transition-delay: 300ms;">
          <div class="asset-placeholder" style="aspect-ratio: 3/4;">
            <span class="asset-placeholder__label">Vineta 3</span>
            <span class="asset-placeholder__specs">600x800 &middot; 3:4<br/>Ilustracion: Mesa con amigos brindando, platos servidos, guitarras al fondo. Como la imagen de la pena pero mas intimo</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <p class="vineta-strip__caption">Comparte la mesa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE TICKER #2 (reverse)
       ============================================ -->
  <Marquee items={['Delivery por Rappi', 'Eventos privados', 'Terraza al aire libre', 'Indie & Rock', 'Vinos de autor', 'Almuerzo ejecutivo']} reverse={true} />

  <!-- ============================================
       RESENAS GOOGLE
       ============================================ -->
  <section class="section comic-panel crosshatch reveal-comic" id="resenas">
    <div class="container reviews">
      <div class="reviews__header">
        <div class="reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="reviews__rating">4.8 / 5</div>
        <p class="reviews__count">Basado en resenas de Google</p>
      </div>
      <div class="reviews__grid">
        <div class="review-card halftone">
          <p class="review-card__text">"Increible lugar, la bondiola es de otro planeta y la terraza una joya del barrio."</p>
          <p class="review-card__author">&mdash; Juan P.</p>
          <p class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
        </div>
        <div class="review-card halftone">
          <p class="review-card__text">"El mejor vermut de la zona. Ambiente relajado y comida honesta. Vuelvo siempre."</p>
          <p class="review-card__author">&mdash; Maria G.</p>
          <p class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
        </div>
        <div class="review-card halftone">
          <p class="review-card__text">"El patio es genial, vinimos con el perro y nos trataron barbaro. Sandwiches enormes."</p>
          <p class="review-card__author">&mdash; Carlos R.</p>
          <p class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       CTAs SERVICIOS — Cards con ink hover
       ============================================ -->
  <section class="section" id="servicios">
    <div class="container">
      <h2 class="text-stencil" style="text-align: center; margin-bottom: var(--space-8);">Que hacemos</h2>
      <div class="grid-services">
        <a href="/eventos" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 0ms;">
          <div class="card-comic__icon-slot asset-placeholder" style="aspect-ratio: 16/9; min-height: 140px;">
            <span class="asset-placeholder__label">Eventos</span>
            <span class="asset-placeholder__specs">800x450 &middot; 16:9<br/>Ilustracion: La terraza decorada para un cumple/evento. Guirnaldas, gente brindando, noche. BYN + luces calidas</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Eventos</h3>
            <p class="card-comic__text">Tu fiesta en la terraza de Saavedra.</p>
          </div>
        </a>
        <a href="/delivery" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 100ms;">
          <div class="card-comic__icon-slot asset-placeholder" style="aspect-ratio: 16/9; min-height: 140px;">
            <span class="asset-placeholder__label">Delivery</span>
            <span class="asset-placeholder__specs">800x450 &middot; 16:9<br/>Ilustracion: El Caudillo en moto/bici con bolsa de comida por calles de Saavedra. Estilo poster propaganda vintage</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Delivery</h3>
            <p class="card-comic__text">Pedi por Rappi y te llega en minutos.</p>
          </div>
        </a>
        <a href="/el-bar" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 200ms;">
          <div class="card-comic__icon-slot asset-placeholder" style="aspect-ratio: 16/9; min-height: 140px;">
            <span class="asset-placeholder__label">Musica</span>
            <span class="asset-placeholder__specs">800x450 &middot; 16:9<br/>Ilustracion: Banda tocando en el bar, guitarras, publico de espaldas con vasos. Como la pena pero vista frontal al escenario</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Musica en vivo</h3>
            <p class="card-comic__text">Indie, rock y buena onda. Los fines de semana.</p>
          </div>
        </a>
        <a href="/el-bar" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 300ms;">
          <div class="card-comic__icon-slot asset-placeholder" style="aspect-ratio: 16/9; min-height: 140px;">
            <span class="asset-placeholder__label">El Bar</span>
            <span class="asset-placeholder__specs">800x450 &middot; 16:9<br/>Ilustracion: Fachada completa del bar de noche con cartel iluminado. Angulo recto, estilo grabado arquitectonico</span>
            <span class="asset-placeholder__type">ilustracion</span>
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">El Bar</h3>
            <p class="card-comic__text">Nuestra historia y por que estamos en Saavedra.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       MAPA + CONTACTO
       ============================================ -->
  <section class="section reveal-comic" id="ubicacion">
    <div class="container" style="text-align: center;">
      <h2 class="text-stencil">Crámer 3198, Saavedra</h2>
      <div style="margin-top: var(--space-6); border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16/9; background: var(--color-bg-card); border: 2px solid var(--color-text-primary);">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3287.2!2d-58.472322!3d-34.5552855!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb70064a4b019%3A0x4258d795fdd55b8c!2sCaudillo%20Bar!5e0!3m2!1ses!2sar!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Caudillo Bar en Google Maps"
        ></iframe>
      </div>
      <div style="margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="https://www.google.com/maps/place/Caudillo+Bar/@-34.5552855,-58.472322,17z/data=!3m1!4b1!4m6!3m5!1s0x95bcb70064a4b019:0x4258d795fdd55b8c" class="btn btn-secondary" target="_blank" rel="noopener">
          Cómo llegar
        </a>
        <a href="https://wa.me/" class="btn btn-primary ink-hover" target="_blank" rel="noopener">
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO OVERRIDES ── */
  .hero__kicker {
    font-size: clamp(0.875rem, 2vw, 1.125rem);
    margin-bottom: var(--space-3);
  }

  .hero__title {
    font-family: var(--font-stencil);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text-heading);
  }

  .hero__asset-note {
    display: none;
  }

  @media (min-width: 768px) {
    .hero__asset-note {
      display: block;
    }
  }

  /* ── INTRO LAYOUT ── */
  .intro-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .intro-layout {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-12);
    }
  }

  /* ── CARD COMIC ── */
  .card-comic {
    background: var(--color-bg-card);
    border: 2px solid var(--color-text-primary);
    border-radius: 2px;
    overflow: hidden;
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .card-comic:hover {
    transform: translateY(-4px) rotate(-0.3deg);
    box-shadow: 6px 6px 0 rgba(200, 53, 42, 0.3);
  }

  .card-comic--link {
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .card-comic__image-slot {
    border-bottom: 2px solid var(--color-text-primary);
    border-radius: 0;
    min-height: 180px;
  }

  .card-comic__icon-slot {
    border-bottom: 2px solid var(--color-text-primary);
    border-radius: 0;
  }

  .card-comic__body {
    padding: var(--space-4) var(--space-5);
  }

  .card-comic__title {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    margin-bottom: var(--space-2);
  }

  .card-comic__text {
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    line-height: var(--lh-body);
  }

  /* ── VINETA STRIP ── */
  .vineta-strip {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .vineta-strip {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }

  .vineta-strip__frame {
    text-align: center;
  }

  .vineta-strip__frame .asset-placeholder {
    border: 3px solid var(--color-text-primary);
    border-radius: 2px;
    margin-bottom: var(--space-3);
  }

  .vineta-strip__caption {
    font-family: var(--font-stencil);
    font-size: clamp(1rem, 2vw, 1.25rem);
    text-transform: uppercase;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }
</style>
