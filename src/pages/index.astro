    border-radius: var(--radius-pill);
  }
</style>

<script>
  // Reviews carousel — animado con GSAP cuando esté disponible, fallback CSS
  // En mobile, cada review-card es un slide individual (carrusel de 1 en 1)
  function initCarousel() {
    const track = document.getElementById('reviews-track') as HTMLElement | null;
    const dots  = document.querySelectorAll<HTMLElement>('.reviews-carousel__dot');
    if (!track) return;

    let current  = 0;
    const total  = 3;
    let isAnimating = false;

    function goTo(index: number) {
      if (isAnimating) return;
      const next = ((index % total) + total) % total;
      if (next === current) return;
      isAnimating = true;

      if (typeof gsap !== 'undefined') {
        gsap.to(track, {
          x: `${-next * 100}%`,
          duration: 0.55,
          ease: 'power2.inOut',
          onComplete: () => { isAnimating = false; },
        });
      } else {
        track.style.transform = `translateX(-${next * 100}%)`;
        isAnimating = false;
      }

      current = next;
      dots.forEach((d, i) => {
        d.classList.toggle('reviews-carousel__dot--active', i === current);
      });
    }

    document.getElementById('reviews-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('reviews-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const delta = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 50) goTo(delta > 0 ? current + 1 : current - 1);
    });
  }

  document.addEventListener('DOMContentLoaded', initCarousel);
</script>
