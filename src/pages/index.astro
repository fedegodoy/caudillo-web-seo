    height: 8px;
    border-radius: 50%;
    background: var(--color-border);
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .reviews-carousel__dot--active {
    background: var(--color-accent);
    width: 24px;
    border-radius: 4px;
  }
</style>

<script>
  // Reviews carousel
  const track = document.getElementById('reviews-track');
  const dots = document.querySelectorAll('.reviews-carousel__dot');
  let current = 0;
  const total = 3;

  function goTo(index: number) {
    // Loop infinito
    current = ((index % total) + total) % total;
    if (track) {
      (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
    }
    dots.forEach((d, i) => {
      d.classList.toggle('reviews-carousel__dot--active', i === current);
    });
  }

  document.getElementById('reviews-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('reviews-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>
