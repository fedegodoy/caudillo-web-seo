---
import BaseLayout from '../layouts/BaseLayout.astro';
import Marquee from '../components/Marquee.astro';

// ── DATOS DE NEGOCIO (single source of truth) ──
const PHONE_RAW = '5491136651186';                      // formato wa.me
const PHONE_DISPLAY = '+54 9 11 3665-1186';
const PHONE_E164 = '+5491136651186';                    // formato schema.org
const WHATSAPP_BASE = `https://wa.me/${PHONE_RAW}`;
const WHATSAPP_RESERVA = `${WHATSAPP_BASE}?text=Hola!%20Quiero%20reservar%20una%20mesa%20en%20Caudillo%20Bar`;
const WHATSAPP_TERRAZA = `${WHATSAPP_BASE}?text=Hola!%20Quiero%20reservar%20la%20terraza%20de%20Caudillo%20Bar`;
const REVIEWS_LINK = 'https://www.google.com/search?q=caudillo+bar+saavedra#lrd=0x95bcb70064a4b019:0x4258d795fdd55b8c,3,,,,';

const schema = {
  "@context": "https://schema.org",
  "@type": ["Bar", "Restaurant"],
  "@id": "https://caudillobar.com.ar/#organization",
  "name": "Caudillo Bar",
  "alternateName": "El Bodegón de Saavedra",
  "url": "https://caudillobar.com.ar/",
  "telephone": PHONE_E164,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Crámer 3198",
    "addressLocality": "Saavedra",
    "addressRegion": "CABA",
    "postalCode": "C1429",
    "addressCountry": "AR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.55390,
    "longitude": -58.48750
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "12:00",
      "closes": "15:30",
      "description": "Mediodía"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "19:00",
      "closes": "23:30",
      "description": "Noche"
    }
  ],
  "servesCuisine": ["Cocina criolla", "Cocina argentina", "Bar"],
  "priceRange": "$$",
  "image": "https://caudillobar.com.ar/images/og-caudillo-bar.jpg",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Terraza al aire libre", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Pet-friendly", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Música en vivo", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Wi-Fi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Salón para eventos", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Delivery", "value": true }
  ],
  "potentialAction": [
    {
      "@type": "ReserveAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": WHATSAPP_RESERVA,
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "result": { "@type": "Reservation", "name": "Reserva de mesa por WhatsApp" }
    },
    {
      "@type": "OrderAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.rappi.com.ar/restaurantes/259123-caudillo-bar",
        "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"]
      },
      "deliveryMethod": "http://purl.org/goodrelations/v1#DeliveryModeOwnFleet"
    }
  ],
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": PHONE_E164,
      "contactType": "reservations",
      "availableLanguage": ["es"],
      "areaServed": "AR"
    }
  ],
  "sameAs": [
    "https://www.instagram.com/caudillobar/",
    "https://www.google.com/maps/place/Caudillo+Bar/@-34.5552855,-58.472322,17z"
  ],
  "hasMenu": {
    "@type": "Menu",
    "url": "https://caudillobar.com.ar/menu"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.7",
    "reviewCount": "165",
    "bestRating": "5",
    "worstRating": "1"
  }
};

const marqueeItems = [
  'Vermut de la casa',
  'Bondiola desmechada',
  'Terraza pet-friendly',
  'Vinos boutique',
  'Música en vivo',
  'Pastel de papas',
  'Ferroviario',
  'Pico y Pala',
  'Negroni',
  'Bife de chorizo',
  'Saavedra, CABA',
];

// 4 íconos de carta — rutas a /menu#anchor
const cartaIcons = [
  { href: '/menu#comida',   label: 'Nuestra carta',   sub: 'Cocina criolla',  icon: '/images/iconos/icono-nuestros-platos.png' },
  { href: '/menu#mediodia', label: 'Menú mediodía',   sub: 'Lun a Vie · 12 a 15:30', icon: '/images/iconos/icono-mediodia.png' },
  { href: '/menu#tragos',   label: 'Nuestros tragos', sub: 'Vermut & coctelería', icon: '/images/iconos/icono-negroni.png' },
  { href: '/menu#vinos',    label: 'Carta de vinos',  sub: 'Boutique argentina', icon: '/images/iconos/icono-vino.png' },
];

// Galería pre-footer — fotos reales
const galleryPreFooter = [
  { src: '/images/galeria/terraza-pet-friendly-caudillo-bar-saavedra.avif',  alt: 'Terraza pet-friendly de Caudillo Bar, Saavedra' },
  { src: '/images/galeria/gente-terraza-caudillo-bar-saavedra.avif',          alt: 'Gente en la terraza de Caudillo Bar' },
  { src: '/images/galeria/ambiente-salon-caudillo-bar-saavedra.avif',         alt: 'Ambiente del salón de Caudillo Bar' },
  { src: '/images/galeria/evento-tertulia-caudillo-bar-saavedra.avif',        alt: 'Evento tertulia en Caudillo Bar' },
  { src: '/images/galeria/gente-vereda-caudillo-bar-saavedra.avif',           alt: 'Gente en la vereda de Caudillo Bar' },
  { src: '/images/galeria/fachada-caudillo-bar-saavedra.avif',                alt: 'Fachada de Caudillo Bar en Saavedra' },
];
---

<BaseLayout
  title="Caudillo Bar | Bodegón Moderno en Saavedra (Crámer 3198)"
  description="Un espacio argentino. Nuevo bodegón en Saavedra: cocina criolla y bar en la terraza. Reservas por WhatsApp. Crámer 3198, CABA."
  schema={schema}
>
  <!-- ============================================
       HERO SECTION — Un espacio argentino
       ============================================ -->
  <section class="hero halftone" id="hero">
    <div class="hero__bg">
      <img src="/images/hero/comiendo-milanesa-plato-caudillo-bar-saavedra.avif" alt="Plato de milanesa en Caudillo Bar, Saavedra" class="hero__bg-img" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__kicker text-stencil text-stencil--red">Crámer 3198 · Saavedra · CABA</p>
      <h1 class="hero__title">Un espacio<br />argentino.</h1>
      <p class="hero__subtitle">
        Nuevo bodegón en Saavedra.<br />Cocina criolla y bar en la terraza.
      </p>
      <div class="hero__actions">
        <a href="/menu" class="btn btn-primary ink-hover">Ver la Carta</a>
        <a href={WHATSAPP_TERRAZA} target="_blank" rel="noopener" class="btn btn-secondary">
          Reservar Terraza
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE TICKER #1
       ============================================ -->
  <Marquee items={marqueeItems} />

  <!-- ============================================
       4 ÍCONOS DE CARTA — accesos rápidos
       ============================================ -->
  <section class="section section--tight" id="carta-shortcuts">
    <div class="container">
      <div class="carta-icons">
        {cartaIcons.map((item, i) => (
          <a href={item.href} class="carta-icon-card reveal-comic" style={`transition-delay: ${i * 80}ms;`}>
            <div class="carta-icon-card__icon-wrap">
              <img src={item.icon} alt={item.label} class="carta-icon-card__img" loading="lazy" />
            </div>
            <h3 class="carta-icon-card__label text-stencil">{item.label}</h3>
            <span class="carta-icon-card__sub">{item.sub}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       3 CAJAS — Delivery / Eventos / Terraza bar
       ============================================ -->
  <section class="section" id="destacados">
    <div class="container">
      <div class="grid-highlights">
        <!-- 1: Delivery -->
        <a href="/delivery" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 0ms;">
          <div class="card-comic__image-slot" style="aspect-ratio: 4/3;">
            <img src="/images/hero/delivery-a-domicilio-caudillo-bar-saavedra.avif" alt="Delivery de Caudillo Bar a domicilio" loading="lazy" />
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Delivery</h3>
            <p class="card-comic__text">Pedí por Rappi y te llega en minutos. Saavedra, Núñez y Coghlan.</p>
          </div>
        </a>

        <!-- 2: Eventos -->
        <a href="/eventos" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 100ms;">
          <div class="card-comic__image-slot" style="aspect-ratio: 4/3;">
            <img src="/images/hero/evento-privado-caudillo-bar-saavedra.avif" alt="Evento privado en la terraza de Caudillo Bar" loading="lazy" />
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Eventos</h3>
            <p class="card-comic__text">Cumpleaños, despedidas, cenas privadas. La terraza es tuya.</p>
          </div>
        </a>

        <!-- 3: Terraza bar -->
        <a href="/el-bar" class="card-comic card-comic--link ink-hover reveal-comic" style="transition-delay: 200ms;">
          <div class="card-comic__image-slot" style="aspect-ratio: 4/3;">
            <img src="/images/hero/terraza-pet-friendly-caudillo-bar-saavedra.avif" alt="Terraza pet-friendly de Caudillo Bar, Saavedra" loading="lazy" />
          </div>
          <div class="card-comic__body">
            <h3 class="card-comic__title text-stencil">Terraza bar</h3>
            <p class="card-comic__text">El mejor spot al aire libre del barrio. Pet-friendly y con vermut de la casa.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       INK DIVIDER
       ============================================ -->
  <div class="ink-divider"></div>

  <!-- ============================================
       MARQUEE TICKER #2 (reverse)
       ============================================ -->
  <Marquee items={['Delivery por Rappi', 'Eventos privados', 'Terraza al aire libre', 'Indie & Rock', 'Vinos de autor', 'Almuerzo ejecutivo']} reverse={true} />

  <!-- ============================================
       RESEÑAS GOOGLE + CTA "Dejá tu reseña"
       ============================================ -->
  <section class="section reveal-comic" id="resenas">
    <div class="container">
      <div class="reviews-box">

      <div class="reviews__header">
        <div class="reviews__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="reviews__rating">4.7 <span style="font-size: 1rem; color: var(--color-text-secondary);">/ 5</span></div>
        <p class="reviews__count">165 opiniones en Google</p>
      </div>

      <div class="reviews-carousel" id="reviews-carousel" aria-label="Reseñas de clientes">
        <div class="reviews-carousel__track" id="reviews-track">

          <!-- Slide 1 — desktop muestra 3, mobile 1 (cada review-card es un slide en mobile) -->
          <div class="reviews-carousel__slide">
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Emilia A. Vélez Serman</strong>
                  <span class="review-card__badge">Local Guide · 14 opiniones</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Desde que llegamos, el personal fue súper cálido y atento. La comida, riquísima y con precios más que razonables. Pedimos provoleta, pastel de papa de osobuco y cerramos con budín de pan con dulce de leche. Todo espectacular. Además, podés pedir un mazo de cartas para jugar mientras esperás y hasta jugar al metegol gratis. Relación precio-calidad excelente. Recomendadísimo, 10/10."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Ramiro Nicolas Gallo</strong>
                  <span class="review-card__badge">4 opiniones</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"El servicio de Caudillo es increíble, la comida riquísima y en especial la atención de Irene no pudo ser mejor. Teníamos dudas sobre qué comer y ella supo recomendarnos las mejores opciones. Sin dudas volveremos."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Valeria Pauletti</strong>
                  <span class="review-card__badge">Local Guide · 25 opiniones</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Excelente lugar, podés encontrar de todo: historia, compromiso, amistad, quizás hasta te enamores. Tiene una terraza amplia y bien decorada. Muy buen sonido. Las empanadas de carne son muy ricas y los tragos también. Las chicas que atienden son muy atentas y simpáticas. Es un lugar donde vas y te sentís bienvenida."</p>
            </div>
          </div>

          <div class="reviews-carousel__slide">
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Tomás Battaglino</strong>
                  <span class="review-card__badge">12 opiniones · 10 fotos</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"El mejor lugar de la zona. Los sanguches son una locura de ricos, el precio excelente, gran carta y una decoración increíble. La terraza con el mural de Cándido López es mágica. Y la onda de los chicos que atienden, la mejor."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Estefanía Enzenhofer</strong>
                  <span class="review-card__badge">Local Guide · 50 opiniones</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Divino el ambiente, la comida, los vinos, los eventos, todo tope de gama."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Lucas Oliveira</strong>
                  <span class="review-card__badge">Local Guide · 54 opiniones · 59 fotos</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Quiero volverme habitué. Comida: 5/5 | Servicio: 5/5 | Ambiente: 5/5."</p>
            </div>
          </div>

          <div class="reviews-carousel__slide">
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Joaquin González</strong>
                  <span class="review-card__badge">Local Guide · 32 opiniones · 9 fotos</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Buen barcito, bien ubicado y con tragos originales, para probar algo distinto. Me gustó el Ferroviario."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Male Goldin</strong>
                  <span class="review-card__badge">11 opiniones · 4 fotos</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Ideal para festejar cumpleaños. La comida muy rica."</p>
            </div>
            <div class="review-card halftone">
              <div class="review-card__meta">
                <div class="review-card__author-info">
                  <strong class="review-card__name">Ignacio Marco Amar</strong>
                  <span class="review-card__badge">Local Guide · 49 opiniones</span>
                </div>
                <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              </div>
              <p class="review-card__text">"Excelente todo. Que dure para siempre."</p>
            </div>
          </div>

        </div><!-- /.reviews-carousel__track -->

        <div class="reviews-carousel__controls">
          <button class="reviews-carousel__btn" id="reviews-prev" aria-label="Reseñas anteriores">&#8592;</button>
          <div class="reviews-carousel__dots" id="reviews-dots">
            <span class="reviews-carousel__dot reviews-carousel__dot--active" data-slide="0"></span>
            <span class="reviews-carousel__dot" data-slide="1"></span>
            <span class="reviews-carousel__dot" data-slide="2"></span>
          </div>
          <button class="reviews-carousel__btn" id="reviews-next" aria-label="Siguientes reseñas">&#8594;</button>
        </div>
      </div>

      <!-- CTA Dejá tu reseña -->
      <div class="reviews__cta">
        <a href={REVIEWS_LINK} target="_blank" rel="noopener" class="btn btn-primary ink-hover">
          Dejá tu reseña en Google
        </a>
        <p class="reviews__cta-note">Tu opinión nos ayuda a seguir mejorando.</p>
      </div>

      </div>{/* /reviews-box */}
    </div>
  </section>

  <!-- ============================================
       GALERÍA PRE-FOOTER — clic abre /galeria
       ============================================ -->
  <section class="section section--tight" id="galeria-preview">
    <div class="container">
      <div class="gallery-preview__header">
        <h2 class="text-stencil">Una mirada al lugar</h2>
        <a href="/galeria" class="gallery-preview__link">Ver galería completa →</a>
      </div>

      <div class="gallery-preview-grid">
        {galleryPreFooter.map((item, i) => (
          <div class={`gallery-preview-grid__cell gallery-preview-grid__cell--${i + 1}`}>
            <img src={item.src} alt={item.alt} loading="lazy" decoding="async" class="gallery-preview-grid__img" />
            <a href="/galeria" class="gallery-preview-grid__overlay" aria-label="Ver galería completa">
              <span class="gallery-preview-grid__hint">Ver galería</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       MAPA + CONTACTO + WHATSAPP
       ============================================ -->
  <section class="section reveal-comic" id="ubicacion">
    <div class="container" style="text-align: center;">
      <h2 class="text-stencil">Crámer 3198, Saavedra</h2>
      <p style="color: var(--color-text-secondary); margin-top: var(--space-2);">A 5 minutos de Núñez y Coghlan · CABA Norte</p>
      <div style="margin-top: var(--space-6); border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 16/5; background: var(--color-bg-card); border: 2px solid var(--color-text-primary);">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3287.2!2d-58.472322!3d-34.5552855!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb70064a4b019%3A0x4258d795fdd55b8c!2sCaudillo%20Bar!5e0!3m2!1ses!2sar!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Caudillo Bar en Google Maps"
        ></iframe>
      </div>
      <div style="margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="https://www.google.com/maps/place/Caudillo+Bar/@-34.5552855,-58.472322,17z/data=!3m1!4b1!4m6!3m5!1s0x95bcb70064a4b019:0x4258d795fdd55b8c" class="btn btn-secondary" target="_blank" rel="noopener">
          Cómo llegar
        </a>
        <a href={WHATSAPP_RESERVA} class="btn btn-primary ink-hover" target="_blank" rel="noopener">
          Reservar por WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO BG IMAGEN REAL ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ── HERO OVERRIDES ── */
  .hero__kicker {
    font-size: clamp(0.875rem, 2vw, 1.125rem);
    margin-bottom: var(--space-3);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.9;
    font-weight: 700;

    letter-spacing: -0.02em;
    color: var(--color-text-heading);
  }

  /* ── SECTION TIGHT (menos padding vertical) ── */
  .section--tight {
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  /* ── SECTION ICONOS — padding extra ── */
  #carta-shortcuts {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  /* ── INTRO LAYOUT ── */
  .intro-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .intro-layout {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-12);
    }
  }

  /* ── 4 ÍCONOS DE CARTA ── */
  .carta-icons {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .carta-icons {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-5);
    }
  }

  .carta-icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-6) var(--space-3);
    background: transparent;
    border: none;
    transition: transform var(--transition-normal);
    text-decoration: none;
    color: inherit;
  }

