---
import BaseLayout from '../layouts/BaseLayout.astro';
import menuData from '../data/menu.json';

const comida = menuData.menus.find(m => m.id === 'comida')!;
const mediodia = menuData.menus.find(m => m.id === 'mediodia')!;
const vinos = menuData.menus.find(m => m.id === 'vinos')!;
const tragos = menuData.menus.find(m => m.id === 'tragos')!;

const schema = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": "Carta de Caudillo Bar",
  "url": "https://caudillobar.com.ar/menu",
  "mainEntity": {
    "@type": "Restaurant",
    "@id": "https://caudillobar.com.ar/#organization"
  },
  "hasMenuSection": comida.sections.map(section => ({
    "@type": "MenuSection",
    "name": section.name,
    "description": section.description || "",
    "hasMenuItem": section.items.map(item => ({
      "@type": "MenuItem",
      "name": item.name,
      "description": item.description,
      "offers": { "@type": "Offer", "price": String(item.price), "priceCurrency": "ARS" },
      ...('suitableForDiet' in item && item.suitableForDiet ? { "suitableForDiet": `https://schema.org/${item.suitableForDiet}` } : {}),
      ...('slug' in item && item.slug ? { "url": `https://caudillobar.com.ar/menu/${item.slug}` } : {})
    }))
  }))
};
---

<BaseLayout
  title="La Carta del Caudillo | Sándwiches y Cocina de la Casa"
  description="Los sándwiches legendarios (Azurduy, Dorrego) y los platos criollos (Pastel de papas, Osobuco). Vermut y vinos seleccionados."
  schema={schema}
  floatingCTAText="Reservar Mesa"
  floatingCTAHref="/contacto"
>
  <section class="section">
    <div class="container">
      <h1>Lo que servimos en la barra.</h1>
    </div>
  </section>

  <!-- TABS -->
  <div class="tabs" role="tablist" aria-label="Secciones del menú">
    <button class="tab tab--active" role="tab" aria-selected="true" data-tab="comida">Comida</button>
    <button class="tab" role="tab" aria-selected="false" data-tab="mediodia">Mediodía</button>
    <button class="tab" role="tab" aria-selected="false" data-tab="vinos">Vinos</button>
    <button class="tab" role="tab" aria-selected="false" data-tab="tragos">Tragos</button>
  </div>

  <!-- TAB: COMIDA -->
  <section class="section" id="comida" data-tab-content="comida">
    <div class="container">
      {comida.sections.map((section, sIdx) => (
        <div style={sIdx > 0 ? `margin-top: var(--space-12);` : ''}>
          <h2>{section.name}</h2>
          {section.description && (
            <p class="text-secondary" style="margin-bottom: var(--space-6);">{section.description}</p>
          )}
          {section.items.map(item => (
            <div class={`menu-item ${sIdx < 2 ? 'reveal reveal-stagger' : ''}`}>
              <div class="menu-item__info">
                {'slug' in item && item.slug ? (
                  <a href={`/menu/${item.slug}`} class="menu-item__name menu-item__name--link">{item.name}</a>
                ) : (
                  <div class="menu-item__name">{item.name}</div>
                )}
                {item.description && <div class="menu-item__desc">{item.description}</div>}
                {'suitableForDiet' in item && item.suitableForDiet && <div class="menu-item__badge">Vegetariano</div>}
              </div>
              <div class="menu-item__price">{item.price}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- TAB: MEDIODÍA (hidden by default) -->
  <section class="section" id="mediodia" data-tab-content="mediodia" style="display: none;">
    <div class="container">
      {mediodia.sections.map((section, sIdx) => (
        <div style={sIdx > 0 ? `margin-top: var(--space-12);` : ''}>
          <h2>{section.name}</h2>
          {section.description && (
            <p class="text-secondary" style="margin-bottom: var(--space-6);">{section.description}</p>
          )}
          {section.items.map(item => (
            <div class="menu-item">
              <div class="menu-item__info">
                <div class="menu-item__name">{item.name}</div>
                {item.description && <div class="menu-item__desc">{item.description}</div>}
              </div>
              <div class="menu-item__price">{item.price}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- TAB: VINOS (hidden by default) -->
  <section class="section" id="vinos" data-tab-content="vinos" style="display: none;">
    <div class="container">
      <h2>Vinos de Bodegas Boutique en Caudillo Bar, Saavedra</h2>
      <p class="text-secondary" style="margin-bottom: var(--space-6);">Selección de bodegas argentinas. Opciones por copa desde 4500.</p>
      {vinos.sections.map((section, sIdx) => (
        <div style={sIdx > 0 ? `margin-top: var(--space-12);` : ''}>
          <h3>{section.name}</h3>
          {section.description && (
            <p class="text-secondary" style="margin-bottom: var(--space-4);">{section.description}</p>
          )}
          {section.items.map(item => (
            <div class="menu-item">
              <div class="menu-item__info">
                <div class="menu-item__name">{item.name}</div>
                {'region' in item && <div class="menu-item__desc">{item.region}</div>}
              </div>
              <div class="menu-item__price-wines">
                {'precio_copa' in item && item.precio_copa && <span class="wine-copa">Copa {item.precio_copa}</span>}
                {'precio_botella' in item && item.precio_botella && <span class="wine-botella">Botella {item.precio_botella}</span>}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- TAB: TRAGOS (hidden by default) -->
  <section class="section" id="tragos" data-tab-content="tragos" style="display: none;">
    <div class="container">
      <h2>Tragos de Autor y Clásicos de Barra</h2>
      <p class="text-secondary" style="margin-bottom: var(--space-6);">Del Ferroviario al Negroni, pasando por el Pico y Pala.</p>
      {tragos.sections.map((section, sIdx) => (
        <div style={sIdx > 0 ? `margin-top: var(--space-12);` : ''}>
          <h3>{section.name}</h3>
          {section.description && (
            <p class="text-secondary" style="margin-bottom: var(--space-4);">{section.description}</p>
          )}
          {section.items.map(item => (
            <div class="menu-item">
              <div class="menu-item__info">
                {'slug' in item && item.slug ? (
                  <a href={`/menu/${item.slug}`} class="menu-item__name menu-item__name--link">{item.name}</a>
                ) : (
                  <div class="menu-item__name">{item.name}</div>
                )}
                {item.description && <div class="menu-item__desc">{item.description}</div>}
              </div>
              <div class="menu-item__price">{item.price}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section" id="menu-cta">
    <div class="container" style="text-align: center;">
      <h2>¿Todo listo?</h2>
      <div style="margin-top: var(--space-6); display: flex; gap: var(--space-3); justify-content: center; flex-wrap: wrap;">
        <a href="https://wa.me/" class="btn btn-primary" target="_blank" rel="noopener">Reservar Mesa por WhatsApp</a>
        <a href="/delivery" class="btn btn-secondary">Pedir por Rappi</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .menu-item__name--link {
    color: var(--color-text-heading);
    text-decoration: none;
    transition: color var(--transition-fast);
    display: inline-block;
  }

  .menu-item__name--link:hover {
    color: var(--color-accent);
  }

  .menu-item__price-wines {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    font-size: var(--text-small);
    white-space: nowrap;
  }

  .wine-copa {
    color: var(--color-text-secondary);
  }

  .wine-botella {
    color: var(--color-text-heading);
    font-weight: 600;
  }
</style>

<script>
  // Tab switching logic
  const tabs = document.querySelectorAll('[role="tab"]');
  const contents = document.querySelectorAll('[data-tab-content]');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;

      // Update tabs
      tabs.forEach(t => {
        t.classList.remove('tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('tab--active');
      tab.setAttribute('aria-selected', 'true');

      // Update content
      contents.forEach(content => {
        const el = content as HTMLElement;
        if (el.dataset.tabContent === target) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  // Handle deep links (#comida, #mediodia, #vinos, #tragos)
  const hash = window.location.hash.replace('#', '');
  if (hash && document.querySelector(`[data-tab="${hash}"]`)) {
    const targetTab = document.querySelector(`[data-tab="${hash}"]`) as HTMLElement;
    targetTab?.click();
  }
</script>
