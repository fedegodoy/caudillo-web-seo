---
import BaseLayout from '../../layouts/BaseLayout.astro';
import menuData from '../../data/menu.json';

export function getStaticPaths() {
  const items: any[] = [];
  for (const menu of menuData.menus) {
    for (const section of menu.sections) {
      for (const item of section.items) {
        if ('slug' in item && item.slug) {
          items.push(item);
        }
      }
    }
  }

  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

const isFood = item.menuType === 'comida';
const isDrink = item.menuType === 'tragos';
const tabAnchor = isFood ? '#comida' : isDrink ? '#tragos' : '#' + item.menuType;

const pageTitle = `${item.name} — Caudillo Bar, Saavedra`;
const pageDescription = item.longDescription
  ? item.longDescription.substring(0, 155)
  : `${item.name}: ${item.description} en Caudillo Bar, Saavedra (CABA). ${isFood ? 'Cocina criolla de barrio.' : 'Barra clásica porteña.'}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "MenuItem",
  "name": item.name,
  "description": item.longDescription || item.description,
  "offers": {
    "@type": "Offer",
    "price": String(item.price),
    "priceCurrency": "ARS"
  },
  ...(item.suitableForDiet ? { "suitableForDiet": `https://schema.org/${item.suitableForDiet}` } : {}),
  "menuAddOn": {
    "@type": "MenuItem",
    "name": "Ver carta completa",
    "url": "https://caudillobar.com.ar/menu"
  },
  "isPartOf": {
    "@type": "Menu",
    "name": "Carta de Caudillo Bar",
    "url": "https://caudillobar.com.ar/menu"
  },
  "provider": {
    "@type": ["Bar", "Restaurant"],
    "@id": "https://caudillobar.com.ar/#organization",
    "name": "Caudillo Bar",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Crámer 3198",
      "addressLocality": "Saavedra",
      "addressRegion": "CABA",
      "addressCountry": "AR"
    }
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schema={schema}
  floatingCTAText="Reservar Mesa"
  floatingCTAHref="https://wa.me/"
>
  <!-- BREADCRUMB -->
  <nav class="breadcrumb section" aria-label="Ubicación">
    <div class="container">
      <ol class="breadcrumb__list">
        <li><a href="/">Inicio</a></li>
        <li><a href="/menu">La Carta</a></li>
        <li aria-current="page">{item.name}</li>
      </ol>
    </div>
  </nav>

  <!-- ITEM DETAIL -->
  <section class="section item-detail">
    <div class="container">
      <div class="item-detail__grid">
        <!-- Image placeholder -->
        <div class="item-detail__image-wrap">
          {item.image ? (
            <div
              class="item-detail__placeholder"
              style={`aspect-ratio: ${item.image.width}/${item.image.height};`}
              role="img"
              aria-label={item.image.alt}
            >
              <div class="item-detail__placeholder-inner">
                <span class="item-detail__placeholder-icon">{isFood ? '🍽️' : '🍸'}</span>
                <span class="item-detail__placeholder-text">Foto próximamente</span>
                <span class="item-detail__placeholder-size">{item.image.width}×{item.image.height}px</span>
              </div>
            </div>
          ) : null}
        </div>

        <!-- Content -->
        <div class="item-detail__content">
          <div class="item-detail__meta">
            <span class="item-detail__section">{item.section}</span>
            {item.suitableForDiet && (
              <span class="item-detail__badge">Vegetariano</span>
            )}
          </div>

          <h1>{item.name} en Caudillo Bar, Saavedra</h1>

          <p class="item-detail__description">
            {item.longDescription || item.description}
          </p>

          <div class="item-detail__price">{item.price}</div>

          <div class="item-detail__actions">
            <a href="https://wa.me/" class="btn btn-primary" target="_blank" rel="noopener">
              Reservar Mesa
            </a>
            <a href={`/menu${tabAnchor}`} class="btn btn-secondary">
              Ver la carta completa
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED CTA -->
  <section class="section reveal" id="item-cta">
    <div class="container" style="text-align: center;">
      <h2>Más de la carta</h2>
      <p class="text-secondary" style="margin-top: var(--space-2); margin-bottom: var(--space-6);">
        {isFood
          ? 'Sánguches de autor, platos de la casa y entradas para compartir.'
          : 'Tragos de la casa, clásicos de barra y vinos boutique de bodegas argentinas.'
        }
      </p>
      <a href="/menu" class="btn btn-secondary">Ver toda la carta</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb */
  .breadcrumb {
    padding-top: var(--space-4);
    padding-bottom: 0;
  }

  .breadcrumb__list {
    display: flex;
    gap: var(--space-2);
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    list-style: none;
    flex-wrap: wrap;
  }

  .breadcrumb__list li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-2);
    color: var(--color-text-secondary);
  }

  .breadcrumb__list a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .breadcrumb__list a:hover {
    color: var(--color-accent);
  }

  .breadcrumb__list [aria-current="page"] {
    color: var(--color-text-heading);
  }

  /* Item Detail */
  .item-detail__grid {
    display: grid;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .item-detail__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  /* Image Placeholder */
  .item-detail__placeholder {
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-border);
  }

  .item-detail__placeholder-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
  }

  .item-detail__placeholder-icon {
    font-size: 3rem;
  }

  .item-detail__placeholder-text {
    font-size: var(--text-body);
    font-weight: 500;
  }

  .item-detail__placeholder-size {
    font-size: var(--text-caption);
    opacity: 0.6;
  }

  /* Content */
  .item-detail__meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .item-detail__section {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .item-detail__badge {
    font-size: var(--text-caption);
    background: rgba(76, 175, 80, 0.15);
    color: #81c784;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  .item-detail h1 {
    font-size: var(--text-h2);
    margin-bottom: var(--space-4);
  }

  @media (min-width: 768px) {
    .item-detail h1 {
      font-size: var(--text-h1);
    }
  }

  .item-detail__description {
    font-size: var(--text-body);
    color: var(--color-text-primary);
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  .item-detail__price {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: var(--space-8);
  }

  .item-detail__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
</style>
